{
  "openapi": "3.0.3",
  "info": {
    "title": "Validation Test",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "required": ["name", "price", "quantity"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "maxLength": 1000
          },
          "price": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "exclusiveMinimum": 0
          },
          "quantity": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "maxItems": 10
          },
          "status": {
            "type": "string",
            "enum": ["draft", "active", "archived"]
          },
          "sku": {
            "type": "string",
            "pattern": "^[A-Z]{2}-[0-9]{4}$"
          }
        }
      },
      "NoConstraints": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      }
    }
  }
}
